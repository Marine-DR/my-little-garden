{
  "name": "my-little-garden",
  "version": "0.1.0",
  "description": "Desktop gardening planner for designing and selecting plants",
  "author": "My Little Garden contributors",
  "desktopName": "My Little Garden",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/database",
    "packages/photo-handling"
  ],
  "main": "dist/main/main/main.js",
  "scripts": {
    "build:core": "tsc -p packages/core/tsconfig.json",
    "build:photo": "tsc -p packages/photo-handling/tsconfig.json",
    "build:database": "npm run build:core && npm run build:photo && tsc -p packages/database/tsconfig.json",
    "build:desktop": "npm run build:database && vite build && tsc -p apps/desktop/tsconfig.json",
    "dist": "npm run build:desktop && electron-builder",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run build:database && tsc -p packages/core/tsconfig.json --noEmit && tsc -p packages/database/tsconfig.json --noEmit && tsc -p apps/desktop/tsconfig.json --noEmit && tsc -p apps/desktop/tsconfig.renderer.json --noEmit && tsc -p apps/desktop/tsconfig.tests.json --noEmit",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "test:core": "npm run build:core && node packages/core/tests/plant.test.cjs",
    "test:database": "npm run build:database && node --test packages/database/tests/initial-schema.test.cjs packages/database/tests/catalog-repository.test.cjs packages/database/tests/selection-repository.test.cjs",
    "test:desktop": "vitest run",
    "test": "npm run lint && npm run typecheck && npm run test:core && npm run test:database && npm run test:desktop",
    "start": "npm run build:desktop && node scripts/start-electron.cjs",
    "demo": "npm run build:desktop && node scripts/start-electron.cjs --demo"
  },
  "build": {
    "appId": "com.mylittlegarden.desktop",
    "productName": "My Little Garden",
    "icon": "apps/desktop/src/renderer/assets/app-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "apps/desktop/resources/**",
      "packages/**",
      "scripts/**",
      "package.json",
      "package-lock.json"
    ],
    "extraResources": [
      {
        "from": "apps/desktop/resources",
        "to": "resources"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "syncDesktopName": true,
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "apps/desktop/src/renderer/assets/app-icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "apps/desktop/src/renderer/assets/app-icon.png"
    }
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@my-little-garden/core": "*",
    "@my-little-garden/database": "*",
    "@my-little-garden/photo-handling": "*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
